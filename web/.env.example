# web/ 复用父仓库的 DATABASE_URL(从 ../.env.local 读),这里通常无需重复设置。
# 如需让 web 连不同的库,可在本文件覆盖:
# DATABASE_URL=postgresql://talent_graph:talent_graph@localhost:5433/talent_graph

# 简单密码门的访问密码(v1 认证;未来迁 Better-auth 后移除)。必填,否则无法登录。
APP_PASSWORD=changeme

# session cookie 加密口令,至少 32 字符。生产务必改成随机长串。
SESSION_SECRET=please-change-this-to-a-long-random-string-min-32-chars

{
  "name": "talent-graph",
  "version": "0.1.1",
  "description": "Tag + canonical entity + alias graph for messy real-world data, with an agent-friendly CLI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/i-richardwang/talent-graph.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "talent-graph": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "build:js": "bun build src/cli.ts src/index.ts --target=node --packages=external --outdir=dist && chmod +x dist/cli.js",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "db": "bun src/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:setup": "bun tools/test/setup-pool.ts",
    "test:teardown": "bun tools/test/teardown-pool.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "csv-parse": "^6.2.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}

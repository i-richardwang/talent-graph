# 复制到 .env.test 后按需修改。
# Base URL 不带 database 名(末尾不要带 /)——helpers 自己拼:
#   - 管理连接走 ${BASE}/postgres
#   - template 库走 ${BASE}/talent_graph_test_template
#   - worker 库走 ${BASE}/talent_graph_test_w<N>
TEST_DATABASE_URL_BASE=postgres://talent_graph:talent_graph@localhost:5434

# Template 库名,无特殊需求别改。仅允许字母数字下划线(setup-pool 会校验)。
TEST_TEMPLATE_DB=talent_graph_test_template

# Worker pool 大小。改完后必须重跑 `bun run test:setup` 重建对应数量 clone。
TEST_WORKER_COUNT=4
